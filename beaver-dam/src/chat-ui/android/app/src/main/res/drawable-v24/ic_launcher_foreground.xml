<?xml version="1.0" encoding="utf-8"?>
<!--
    Beaver pixel-art icon (16x16) centred in a 24x24 viewport.
    4-unit padding on each side keeps art inside the adaptive-icon safe zone (72dp of 108dp).
    All coordinates = original SVG coord + 4.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- zinc-600: antenna -->
    <path
        android:fillColor="#52525b"
        android:pathData="M 11,4 h 1 v 1 h -1 Z  M 10,5 h 3 v 1 h -3 Z" />

    <!-- orange-700: ear outlines + snout -->
    <path
        android:fillColor="#c2410c"
        android:pathData="M 6,6 h 2 v 1 h -2 Z  M 6,7 h 1 v 1 h -1 Z  M 8,7 h 1 v 1 h -1 Z
                          M 16,6 h 2 v 1 h -2 Z  M 15,7 h 1 v 1 h -1 Z  M 17,7 h 1 v 1 h -1 Z
                          M 9,14 h 6 v 1 h -6 Z
                          M 8,15 h 1 v 2 h -1 Z  M 11,15 h 2 v 2 h -2 Z  M 15,15 h 1 v 2 h -1 Z" />

    <!-- orange-500: ear fill + head -->
    <path
        android:fillColor="#f97316"
        android:pathData="M 7,7 h 1 v 1 h -1 Z  M 16,7 h 1 v 1 h -1 Z
                          M 7,8 h 10 v 2 h -10 Z
                          M 7,10 h 1 v 3 h -1 Z  M 11,10 h 2 v 3 h -2 Z  M 16,10 h 1 v 3 h -1 Z
                          M 7,13 h 10 v 1 h -10 Z
                          M 7,14 h 2 v 1 h -2 Z  M 15,14 h 2 v 1 h -2 Z
                          M 7,15 h 1 v 2 h -1 Z  M 16,15 h 1 v 2 h -1 Z" />

    <!-- zinc-900: head outline + eye sockets -->
    <path
        android:fillColor="#18181b"
        android:pathData="M 6,8 h 1 v 10 h -1 Z  M 17,8 h 1 v 10 h -1 Z  M 7,17 h 10 v 1 h -10 Z
                          M 8,10 h 3 v 3 h -3 Z  M 13,10 h 3 v 3 h -3 Z" />

    <!-- white: buck teeth -->
    <path
        android:fillColor="#ffffff"
        android:pathData="M 9,15 h 2 v 2 h -2 Z  M 13,15 h 2 v 2 h -2 Z" />

    <!-- cyan-500: LED eyes -->
    <path
        android:fillColor="#06b6d4"
        android:pathData="M 9,11 h 1 v 1 h -1 Z  M 14,11 h 1 v 1 h -1 Z" />
</vector>
